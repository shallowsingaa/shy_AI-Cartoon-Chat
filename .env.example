# 复制为 .env 后填入真实值（.env 已被 .gitignore 忽略，不会上传）
DASHSCOPE_KEY=在此填入你的_API_KEY
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
MODEL=qwen-plus
PORT=3000
UPSTREAM_TIMEOUT_MS=30000
CHAT_MAX_CONCURRENCY=24
TTS_MAX_CONCURRENCY=6

# ===== MiniMax 语音合成（TTS，可选）=====
# 不配则自动禁用语音朗读，文字聊天照常
MINIMAX_API_KEY=在此填入你的_MiniMax_API_KEY
MINIMAX_GROUP_ID=可留空（找不到就先空着）
MINIMAX_TTS_BASE_URL=https://api.minimax.chat/v1/t2a_v2
MINIMAX_TTS_MODEL=speech-02-turbo
MINIMAX_VOICE_ID=female-tianmei
MINIMAX_TTS_SPEED=1.0
MINIMAX_TTS_PITCH=0
MINIMAX_VOICE_ID_NO4=male-qn-qingse-jingpin
MINIMAX_TTS_SPEED_NO4=1.05
MINIMAX_TTS_PITCH_NO4=2
